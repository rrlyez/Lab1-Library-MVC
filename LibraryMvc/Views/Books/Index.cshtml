@model IEnumerable<LibraryMvc.Models.Book>

@{
    ViewData["Title"] = "Books";
    Layout = "_Layout";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>
    <p>
        <a asp-action="Create">Create New</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Title)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Isbn)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.PublishYear)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.CopiesCount)
                </th>
                <th>
                    Publisher
                </th>
                <th>
                    Authors
                </th>
                <th>
                    Genres
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Title)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Isbn)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.PublishYear)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.CopiesCount)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Publisher.Name)
                    </td>
                    <td>
                        @(item.Authors != null && item.Authors.Any()
                                            ? string.Join(", ", item.Authors.Select(a => a.FirstName + " " + a.LastName))
                                            : "-")
                    </td>
                    <td>
                        @(item.Genres != null && item.Genres.Any()
                                            ? string.Join(", ", item.Genres.Select(g => g.Name))
                                            : "-")
                    </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookId">Delete</a>
                </td>
            </tr>
                        }
        </tbody>
    </table>
    <div class="row mt-4">
        <div class="col-12">
            <div id="booksByYearChart"></div>
        </div>
    </div>
</body>
</html>
@section Scripts
{
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', { 'packages': ['corechart'] });
        google.charts.setOnLoadCallback(drawBooksByYearChart);

        function isDarkTheme() {
            return document.documentElement.classList.contains("dark-theme");
        }

        function getBooksChartOptions() {
            if (isDarkTheme()) {
                return {
                    title: 'Books by publication year',
                    width: 800,
                    height: 400,
                    legend: { position: 'none' },
                    backgroundColor: '#1b1b1b',
                    chartArea: {
                        backgroundColor: '#1b1b1b'
                    },
                    titleTextStyle: {
                        color: '#f3e7d0',
                        fontSize: 18,
                        bold: true
                    },
                    hAxis: {
                        textStyle: { color: '#f1f1f1' },
                        titleTextStyle: { color: '#f1f1f1' },
                        gridlines: { color: '#444' },
                        baselineColor: '#666'
                    },
                    vAxis: {
                        textStyle: { color: '#f1f1f1' },
                        titleTextStyle: { color: '#f1f1f1' },
                        gridlines: { color: '#444' },
                        baselineColor: '#666'
                    }
                };
            }

            return {
                title: 'Books by publication year',
                width: 800,
                height: 400,
                legend: { position: 'none' },
                backgroundColor: '#ffffff',
                chartArea: {
                    backgroundColor: '#ffffff'
                },
                titleTextStyle: {
                    color: '#234b3b',
                    fontSize: 18,
                    bold: true
                },
                hAxis: {
                    textStyle: { color: '#2f2f2f' },
                    titleTextStyle: { color: '#2f2f2f' },
                    gridlines: { color: '#ddd' },
                    baselineColor: '#999'
                },
                vAxis: {
                    textStyle: { color: '#2f2f2f' },
                    titleTextStyle: { color: '#2f2f2f' },
                    gridlines: { color: '#ddd' },
                    baselineColor: '#999'
                }
            };
        }

        function drawBooksByYearChart() {
            fetch('/api/charts/booksByYear')
                .then(response => response.json())
                .then(data => {
                    const dataTable = new google.visualization.DataTable();
                    dataTable.addColumn('string', 'Year');
                    dataTable.addColumn('number', 'Books count');

                    data.forEach(item => {
                        dataTable.addRow([item.year, item.count]);
                    });

                    const options = getBooksChartOptions();

                    const chart = new google.visualization.ColumnChart(
                        document.getElementById('booksByYearChart')
                    );
                    chart.draw(dataTable, options);
                });
        }

        document.addEventListener("DOMContentLoaded", function () {
            const themeToggle = document.getElementById("theme-toggle");

            if (themeToggle) {
                themeToggle.addEventListener("click", function () {
                    setTimeout(drawBooksByYearChart, 50);
                });
            }
        });
    </script>
}