@model IEnumerable<LibraryMvc.Models.Issue>

@{
    ViewData["Title"] = "Issues";
    Layout = "_Layout";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>

    <p>
        <a asp-action="Create">Create New</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>Issue Date</th>
                <th>Due Date</th>
                <th>Return Date</th>
                <th>Book</th>
                <th>Reader</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @item.IssueDate.Value.ToString("dd.MM.yyyy")
                    </td>
                    <td>
                        @item.DueDate.Value.ToString("dd.MM.yyyy")
                    </td>
                    <td>
                        @(item.ReturnDate.HasValue? item.ReturnDate.Value.ToString("dd.MM.yyyy") : "-")
                    </td>
                    <td>
                        @item.Book.Title
                    </td>
                    <td>
                        @item.Reader.FullName
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.IssueId">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.IssueId">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.IssueId">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="row mt-4">
        <div class="col-12">
            <div id="issuesByReaderChart"></div>
        </div>
    </div>
</body>
</html>
@section Scripts
{
    <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    <script type="text/javascript">
        google.charts.load('current', { 'packages': ['corechart'] });
        google.charts.setOnLoadCallback(drawIssuesByReaderChart);

        function isDarkTheme() {
            return document.documentElement.classList.contains("dark-theme");
        }

        function getIssuesChartOptions() {
            if (isDarkTheme()) {
                return {
                    title: 'Issued books by reader',
                    width: 800,
                    height: 400,
                    legend: { position: 'none' },
                    backgroundColor: '#1b1b1b',
                    chartArea: {
                        backgroundColor: '#1b1b1b'
                    },
                    titleTextStyle: {
                        color: '#f3e7d0',
                        fontSize: 18,
                        bold: true
                    },
                    hAxis: {
                        textStyle: { color: '#f1f1f1' },
                        titleTextStyle: { color: '#f1f1f1' },
                        gridlines: { color: '#444' },
                        baselineColor: '#666'
                    },
                    vAxis: {
                        textStyle: { color: '#f1f1f1' },
                        titleTextStyle: { color: '#f1f1f1' },
                        gridlines: { color: '#444' },
                        baselineColor: '#666'
                    }
                };
            }

            return {
                title: 'Issued books by reader',
                width: 800,
                height: 400,
                legend: { position: 'none' },
                backgroundColor: '#ffffff',
                chartArea: {
                    backgroundColor: '#ffffff'
                },
                titleTextStyle: {
                    color: '#234b3b',
                    fontSize: 18,
                    bold: true
                },
                hAxis: {
                    textStyle: { color: '#2f2f2f' },
                    titleTextStyle: { color: '#2f2f2f' },
                    gridlines: { color: '#ddd' },
                    baselineColor: '#999'
                },
                vAxis: {
                    textStyle: { color: '#2f2f2f' },
                    titleTextStyle: { color: '#2f2f2f' },
                    gridlines: { color: '#ddd' },
                    baselineColor: '#999'
                }
            };
        }

        function drawIssuesByReaderChart() {
            fetch('/api/charts/issuesByReader')
                .then(response => response.json())
                .then(data => {
                    const dataTable = new google.visualization.DataTable();
                    dataTable.addColumn('string', 'Reader');
                    dataTable.addColumn('number', 'Issues count');

                    data.forEach(item => {
                        dataTable.addRow([item.reader, item.count]);
                    });

                    const options = getIssuesChartOptions();

                    const chart = new google.visualization.ColumnChart(
                        document.getElementById('issuesByReaderChart')
                    );
                    chart.draw(dataTable, options);
                });
        }

        document.addEventListener("DOMContentLoaded", function () {
            drawIssuesByReaderChart();
            const themeToggle = document.getElementById("theme-toggle");

            if (themeToggle) {
                themeToggle.addEventListener("click", function () {
                    setTimeout(drawIssuesByReaderChart, 50);
                });
            }
        });
    </script>
}
